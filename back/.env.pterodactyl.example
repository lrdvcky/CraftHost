# =============================================================================
# Pterodactyl Panel integration
# =============================================================================
# Пока PTERODACTYL_API_KEY пустой — сервис в STUB-режиме (фейковый IP/port).
# Заполни ключи и сделай `php artisan config:clear` — переключится в боевой.
# =============================================================================
PTERODACTYL_URL=https://panel.example.com
PTERODACTYL_API_KEY=
PTERODACTYL_CLIENT_KEY=
PTERODACTYL_NODE_ID=1
PTERODACTYL_TIMEOUT=15

# Маппинг mc_version → egg ID (fallback если в таблице mc_versions нет egg).
PTERO_EGG_VANILLA=1
PTERO_EGG_PAPER=3
PTERO_EGG_FORGE=5
PTERO_EGG_FABRIC=7

# =============================================================================
# Queue: sync (ok для dev), database или redis (prod).
# Для async провизии: `php artisan queue:work --queue=provisioning`
# =============================================================================
QUEUE_CONNECTION=sync

# Cache используется в Setting::get(); по умолчанию file — норм.
CACHE_DRIVER=file

# =============================================================================
# Платёжные системы
# =============================================================================
# Провайдер по умолчанию. Пока боевые ключи не заданы — менеджер автоматически
# откатывается на 'stub' (тестовая оплата зачисляет баланс без реальной платёжки).
PAYMENTS_DEFAULT=stub
PAYMENTS_STUB_AUTOCOMPLETE=true

# URL фронтенда — куда платёжка вернёт пользователя после оплаты.
FRONTEND_URL=http://localhost:5173

# ЮKassa (заполнить при подключении): https://yookassa.ru/my
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
# Webhook в личном кабинете ЮKassa указать на:
#   https://ВАШ_ДОМЕН/api/payments/webhook/yookassa
